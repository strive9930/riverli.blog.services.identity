<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
  <config>
    <!-- 使用默认的全局包文件夹，自动适配各平台 -->
    <!-- Windows: %userprofile%\.nuget\packages -->
    <!-- macOS/Linux: ~/.nuget/packages -->
  </config>
</configuration>
