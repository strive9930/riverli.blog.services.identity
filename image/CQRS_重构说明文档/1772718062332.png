### 步骤 4：将业务逻辑从 Controller 移至 QueryHandler

以 `FrontendRouteController` 中树形构建逻辑为例：

#### ❌ 重构前（错误示范）

```csharp
// Controller 中出现业务逻辑
[HttpGet("tree")]
public async Task<IActionResult> GetFrontendRouteTree()
{
    var query = new GetAllFrontendRoutesQuery();
    var result = await _mediator.Send(query);
    if (!result.Success) return Fail(result.Message);

    var routes = result.Data;
    var rootRoutes = routes
        .Where(r => r.ParentId == null)
        .OrderBy(r => r.Sort).ToList();

    foreach (var root in rootRoutes)
        BuildRouteTree(root, routes);  // ← 业务逻辑不应在此

    return Success(rootRoutes);
}
```

#### ✅ 重构后（正确做法）

**Controller 只做 HTTP 适配：**

```csharp
[HttpGet("tree")]
public async Task<IActionResult> GetFrontendRouteTree()
{
    var result = await _mediator.Send(
        new GetFrontendRouteTreeQuery());
    return result.Success
        ? Success(result.Data)
        : Fail(result.Message);
}
```

**树形构建逻辑移至 QueryHandler：**

```csharp
// Application/FrontendRoutes/Queries/GetFrontendRouteTree/
// GetFrontendRouteTreeQuery.cs
public record GetFrontendRouteTreeQuery
    : IRequest<Result<List<FrontendRouteTreeDto>>>;

public class FrontendRouteTreeDto
{
    public Guid Id { get; set; }
    public string Path { get; set; } = string.Empty;
    public string Name { get; set; } = string.Empty;
    public string? Title { get; set; }
    public int Sort { get; set; }
    public bool IsEnabled { get; set; }
    public List<FrontendRouteTreeDto> Children { get; set; } = new();
}

// GetFrontendRouteTreeQueryHandler.cs
public class GetFrontendRouteTreeQueryHandler
    : IRequestHandler<GetFrontendRouteTreeQuery,
                      Result<List<FrontendRouteTreeDto>>>
{
    private readonly IdentityServiceDbContext _context;

    public GetFrontendRouteTreeQueryHandler(
        IdentityServiceDbContext context)
        => _context = context;

    public async Task<Result<List<FrontendRouteTreeDto>>>
        Handle(GetFrontendRouteTreeQuery request,
               CancellationToken cancellationToken)
    {
        var all = await _context.FrontendRoutes
            .AsNoTracking()
            .OrderBy(r => r.Sort)
            .ToListAsync(cancellationToken);

        var roots = all
            .Where(r => r.ParentId == null)
            .Select(r => ToDto(r, all))
            .ToList();

        return Result<List<FrontendRouteTreeDto>>
            .SuccessResult(roots);
    }

    private static FrontendRouteTreeDto ToDto(
        FrontendRoute route,
        List<FrontendRoute> all)
    {
        return new FrontendRouteTreeDto
        {
            Id = route.Id,
            Path = route.Path,
            Name = route.Name,
            Title = route.Title,
            Sort = route.Sort,
            IsEnabled = route.IsEnabled,
            Children = all
                .Where(r => r.ParentId == route.Id)
                .Select(r => ToDto(r, all))
                .ToList()
        };
    }
}
```

