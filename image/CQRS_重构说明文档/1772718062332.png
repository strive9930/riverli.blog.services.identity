`GetAllUsersQuery` 目前直接返回 `PagedResult<UserDto>`（未包在 `Result<T>` 外层），需要统一：

```csharp
// 重构前（不一致）
public record GetAllUsersQuery(...)
    : IRequest<PagedResult<UserDto>>;  // ❌ 未包在 Result 外层

// 重构后（统一）
public record GetAllUsersQuery(
    string? Keyword = null,
    bool? IsEnabled = null,
    int PageIndex = 1,
    int PageSize = 10
) : IRequest<Result<PagedResult<UserDto>>>;  // ✅ 统一包在 Result 中

// Handler 同步修改返回类型
public class GetAllUsersQueryHandler
    : IRequestHandler<GetAllUsersQuery,
                      Result<PagedResult<UserDto>>>
{
    public async Task<Result<PagedResult<UserDto>>>
        Handle(GetAllUsersQuery request,
               CancellationToken cancellationToken)
    {
        // ...构建分页结果...
        return Result<PagedResult<UserDto>>.SuccessResult(pagedResult);
    }
}
```

