# 自动检测文本文件并处理行尾符
* text=auto

# C# 源代码文件
*.cs text diff=csharp
*.csproj text
*.sln text
*.config text
*.json text

# 配置文件
*.xml text
*.yaml text
*.yml text

# 脚本文件
*.sh text eol=lf
*.bash text eol=lf
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf

# 文档文件
*.md text
*.txt text

# Web 文件
*.html text
*.css text
*.js text
*.ts text

# 数据文件
*.sql text
*.csv text

# 二进制文件（不转换）
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.dll binary
*.exe binary
*.zip binary
*.nupkg binary
